GROQ_API_KEY=
HOST=0.0.0.0
PORT=8082
RELOAD=false
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# --- TrueFoundry AI Gateway (Tier-1 model resilience) ---
TFY_API_KEY=
TFY_BASE_URL=https://gateway.truefoundry.ai
TFY_MODEL=insuriq-production/resilient-agent-insuriq
TFY_MODEL_CHAOS=insuriq-production-chaos/resilient-agent-chaos

# --- MCP server (Step 5.2 spike) ---
# Port the thin MCP server binds (the `mcp` compose service). Default 8081.
MCP_HOST=0.0.0.0
MCP_PORT=8081

# --- MCP client path (graph -> TFY MCP Gateway) ---
# Comma-separated tool names to route THROUGH the gateway. Leave EMPTY to keep
# every tool on its local function (default; full regression). Spike value:
#   USE_MCP_FOR=get_waiting_periods
USE_MCP_FOR=
# The gateway MCP endpoint. SSE is used when the path contains "/sse", else
# streamable-HTTP. (Point at the local server for a gateway-free round-trip:
#   TFY_MCP_URL=http://localhost:8081/sse )
TFY_MCP_URL=
TFY_MCP_TOKEN=
